# ===========================================
# News Agent Collector - API Keys & Config
# ===========================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# NEVER commit .env to version control.

# --- News & Search APIs ---
TAVILY_API_KEY=
EVENT_REGISTRY_API_KEY=   # newsapi.ai UUID key (replaces NEWSAPI_API_KEY)
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# --- LLM / Summarization ---
GROQ_API_KEY=

# --- Social Platforms ---
# Reddit: Skipped — API policy changes make free access unreliable
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=NewsAgentCollector/1.0

GITHUB_TOKEN=

# --- Academic ---
SEMANTIC_SCHOLAR_API_KEY=

# --- Email Delivery ---
RESEND_API_KEY=
DELIVERY_EMAIL_TO=your@email.com
DELIVERY_EMAIL_FROM=News Agent <onboarding@resend.dev>

# --- Click Tracking (Cloudflare Worker) ---
CLOUDFLARE_WORKER_URL=https://newsagent-tracker.YOUR_SUBDOMAIN.workers.dev
CLOUDFLARE_WORKER_SECRET=your-random-secret-here

# --- Shutdown Behaviour ---
SHUTDOWN_AFTER_DELIVERY=true
SHUTDOWN_DOCKER_AFTER_DELIVERY=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/news_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/news_agent

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
