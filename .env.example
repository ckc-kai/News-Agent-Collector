# ===========================================
# News Agent Collector - API Keys & Config
# ===========================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# NEVER commit .env to version control.

# --- News & Search APIs ---
TAVILY_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# --- LLM / Summarization ---
GROQ_API_KEY=

# --- Social Platforms ---
# Reddit: Skipped — API policy changes make free access unreliable
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=NewsAgentCollector/1.0

GITHUB_TOKEN=

# --- Academic ---
SEMANTIC_SCHOLAR_API_KEY=

# --- Email (Phase 2 — not needed yet) ---
# SENDGRID_API_KEY=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/news_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/news_agent

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
